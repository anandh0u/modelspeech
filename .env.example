# EmoMemory Environment Configuration
# Copy this file to .env and fill in your values

# ==========================================
# Application Settings
# ==========================================
ENVIRONMENT=production
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ==========================================
# Cognee Cloud Configuration
# ==========================================
COGNEE_API_KEY=your_cognee_api_key_here
COGNEE_API_URL=https://api.cognee.ai
COGNEE_DATASET=emomemory_production
COGNEE_USE_CLOUD=true

# ==========================================
# Database Configuration
# ==========================================
DATABASE_URL=postgresql://user:password@localhost:5432/emomemory

# For development (SQLite):
# DATABASE_URL=sqlite:///./emomemory.db

# ==========================================
# Security & Authentication
# ==========================================
SECRET_KEY=change-this-to-a-random-secret-key-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24 hours
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==========================================
# Wallet & Billing
# ==========================================
WALLET_CURRENCY=USD
FREE_TIER_CREDITS=10.0

# Pricing (in credits)
COST_PER_PREDICTION=0.1
COST_PER_CHAT_MESSAGE=0.05
COST_PER_MEMORY_QUERY=0.02
COST_PER_COGNIFY=1.0

# ==========================================
# Payment Gateway (Optional)
# ==========================================
# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal (Alternative)
# PAYPAL_CLIENT_ID=...
# PAYPAL_CLIENT_SECRET=...

# ==========================================
# Email Configuration (Optional)
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=noreply@emomemory.app

# ==========================================
# Rate Limiting
# ==========================================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ==========================================
# CORS Origins
# ==========================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,https://emomemory.app

# ==========================================
# Monitoring & Analytics (Optional)
# ==========================================
# SENTRY_DSN=https://...@sentry.io/...
# GOOGLE_ANALYTICS_ID=G-...

# ==========================================
# Redis (Optional - for caching)
# ==========================================
# REDIS_URL=redis://localhost:6379

# ==========================================
# Feature Flags
# ==========================================
ENABLE_AUTHENTICATION=true
ENABLE_WALLET=true
ENABLE_ANALYTICS=true
ENABLE_RATE_LIMITING=true

# ==========================================
# Development Settings
# ==========================================
SKIP_CONFIG_VALIDATION=false
